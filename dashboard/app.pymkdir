        monocytes   = st.number_input("單核球 Monocytes (×10³/μL)",     min_value=0.1, value=0.5, step=0.1)

    # 自動計算發炎指標
    nlr, plr, lmr, sii = calculate_biomarkers(neutrophils, lymphocytes, platelets, monocytes)

