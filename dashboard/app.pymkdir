    c2.metric("PLR", f"{plr:.2f}", help="血小板/淋巴球比值，正常值 < 150")
    c3.metric("LMR", f"{lmr:.2f}", help="淋巴球/單核球比值，正常值 > 4")
    c4.metric("SII", f"{sii:.2f}", help="全身性免疫發炎指數，正常值 < 600")

    st.markdown("---")

